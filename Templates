<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mavi Zuccaciye - Stüdyo Foto Üretici</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .container {
            background: #1a1a1a;
            border-radius: 16px;
            padding: 40px;
            max-width: 500px;
            width: 100%;
            border: 1px solid #333;
        }
        .logo {
            text-align: center;
            margin-bottom: 30px;
        }
        .logo h1 {
            font-size: 22px;
            font-weight: 600;
            color: #c0392b;
        }
        .logo p {
            font-size: 13px;
            color: #888;
            margin-top: 4px;
        }
        .upload-area {
            border: 2px dashed #444;
            border-radius: 12px;
            padding: 40px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 20px;
            position: relative;
        }
        .upload-area:hover { border-color: #c0392b; background: #1f1f1f; }
        .upload-area input { display: none; }
        .upload-area .icon { font-size: 36px; margin-bottom: 10px; }
        .upload-area p { font-size: 14px; color: #888; }
        .upload-area.has-image { border-color: #27ae60; }
        #preview {
            width: 100%;
            max-height: 200px;
            object-fit: contain;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }
        .btn {
            width: 100%;
            padding: 14px;
            background: #c0392b;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn:hover { background: #a93226; }
        .btn:disabled { background: #555; cursor: not-allowed; }
        .status {
            margin-top: 20px;
            padding: 16px;
            background: #111;
            border-radius: 10px;
            font-size: 13px;
            line-height: 1.8;
            display: none;
        }
        .status.show { display: block; }
        .step { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .step .dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #555;
            flex-shrink: 0;
        }
        .step.active .dot { background: #f39c12; animation: pulse 1s infinite; }
        .step.done .dot { background: #27ae60; }
        .step.error .dot { background: #c0392b; }
        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
        .result {
            margin-top: 16px;
            padding: 12px;
            background: #1a2a1a;
            border-radius: 8px;
            border: 1px solid #27ae60;
            font-size: 12px;
            color: #2ecc71;
            display: none;
        }
        .result.show { display: block; }
        .studio-preview {
            margin-top: 16px;
            text-align: center;
            display: none;
        }
        .studio-preview.show { display: block; }
        .studio-preview img {
            max-width: 100%;
            max-height: 300px;
            border-radius: 8px;
            border: 1px solid #333;
        }
        .studio-preview p { font-size: 12px; color: #888; margin-top: 8px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <h1>Mavi Zuccaciye</h1>
            <p>Stüdyo Fotoğraf Üretici</p>
        </div>

        <div class="upload-area" id="uploadArea" onclick="document.getElementById('fileInput').click()">
            <input type="file" id="fileInput" accept="image/*" onchange="handleFile(event)">
            <div class="icon">📷</div>
            <p id="uploadText">Ürün fotoğrafı yükle</p>
        </div>

        <img id="preview" alt="Ürün önizleme">

        <button class="btn" id="processBtn" onclick="process()" disabled>
            Stüdyo Fotoğrafı Oluştur
        </button>

        <div class="status" id="status">
            <div class="step" id="step1"><div class="dot"></div><span>Ürün analiz ediliyor...</span></div>
            <div class="step" id="step2"><div class="dot"></div><span>Stüdyo prompt üretiliyor...</span></div>
            <div class="step" id="step3"><div class="dot"></div><span>Görsel oluşturuluyor (Gemini Imagen)...</span></div>
            <div class="step" id="step4"><div class="dot"></div><span>Canva'ya yükleniyor...</span></div>
        </div>

        <div class="studio-preview" id="studioPreview">
            <img id="studioImg" alt="Stüdyo görseli">
            <p>Stüdyo görseli oluşturuldu!</p>
        </div>

        <div class="result" id="result"></div>
    </div>

    <script>
        let selectedFile = null;

        function handleFile(e) {
            const file = e.target.files[0];
            if (!file) return;
            selectedFile = file;

            const reader = new FileReader();
            reader.onload = (ev) => {
                document.getElementById('preview').src = ev.target.result;
                document.getElementById('preview').style.display = 'block';
                document.getElementById('uploadText').textContent = '✓ ' + file.name;
                document.getElementById('uploadArea').classList.add('has-image');
                document.getElementById('processBtn').disabled = false;
            };
            reader.readAsDataURL(file);
        }

        function setStep(stepId, state) {
            const el = document.getElementById(stepId);
            el.className = 'step ' + state;
        }

        async function process() {
            if (!selectedFile) return;

            const btn = document.getElementById('processBtn');
            btn.disabled = true;
            btn.textContent = 'İşleniyor...';

            const status = document.getElementById('status');
            status.classList.add('show');

            document.getElementById('result').classList.remove('show');
            document.getElementById('studioPreview').classList.remove('show');

            setStep('step1', 'active');
            setStep('step2', '');
            setStep('step3', '');
            setStep('step4', '');

            try {
                const formData = new FormData();
                formData.append('image', selectedFile);

                setStep('step1', 'active');
                setStep('step2', 'active');

                const response = await fetch('/process', {
                    method: 'POST',
                    body: formData
                });

                setStep('step1', 'done');
                setStep('step2', 'done');
                setStep('step3', 'active');

                const data = await response.json();

                if (data.error) throw new Error(data.error);

                setStep('step3', 'done');
                setStep('step4', 'done');

                const result = document.getElementById('result');
                result.innerHTML = `✅ Tamamlandı!<br><br>Asset ID: <strong>${data.asset_id}</strong><br><br>Canva'ya yüklendi, şablona otomatik eklenecek.`;
                result.classList.add('show');

            } catch (err) {
                setStep('step1', 'error');
                const result = document.getElementById('result');
                result.innerHTML = `❌ Hata: ${err.message}`;
                result.style.borderColor = '#c0392b';
                result.style.color = '#e74c3c';
                result.style.background = '#2a1a1a';
                result.classList.add('show');
            }

            btn.disabled = false;
            btn.textContent = 'Stüdyo Fotoğrafı Oluştur';
        }
    </script>
</body>
</html>
